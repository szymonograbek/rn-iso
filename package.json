{
  "name": "rn-iso",
  "version": "1.0.0",
  "description": "Isolated React Native dev environments per project/worktree",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "npm run build && node --test dist/**/*.test.js",
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "dev": "tsx src/cli.ts",
    "check": "tsc --noEmit -p tsconfig.json"
  },
  "type": "module",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "prompts": "^2.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "rn-iso": "./dist/cli.js"
  },
  "keywords": [
    "react-native",
    "expo",
    "metro",
    "simulator",
    "emulator",
    "worktree",
    "agent"
  ]
}
